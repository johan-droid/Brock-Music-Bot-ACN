```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Logs and temporary files
*.log
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
.coverage
coverage/
htmlcov/

# Build artifacts
dist/
build/
target/
*.class
*.jar

# MyPy cache
.mypy_cache/
# Pytest cache
.pytest_cache/

# OS generated files
.DS_Store
Thumbs.db

# Configuration backup files
*.bak
*.backup
```