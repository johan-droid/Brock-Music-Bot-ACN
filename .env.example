# ============================================================
# Brook Music Bot - guided environment example
# Updated for the current client-bot architecture
# Copy this file to .env and replace the example values below.
# ============================================================


# ============================================================
# 1) REQUIRED TELEGRAM APP CREDENTIALS
# Get these from: https://my.telegram.org
# Required when TELEGRAM_ENABLED=true
# ============================================================
TELEGRAM_ENABLED=true
API_ID=12345678
API_HASH=0123456789abcdef0123456789abcdef


# ============================================================
# 2) REQUIRED BOT TOKEN
# Get this from @BotFather
# ============================================================
BOT_TOKEN=1234567890:AAExampleBotTokenReplaceMe


# ============================================================
# 3) REQUIRED OWNER
# Your personal Telegram numeric user ID.
# This is the account that owns/admins the bot.
# ============================================================
OWNER_ID=123456789


# ============================================================
# 4) REQUIRED ASSISTANT LOGIN
# You need at least one assistant account for voice chats.
#
# Fill only ONE method for each slot:
# - SESSION_STRING_1      -> easiest for most users
# - SESSION_FILE_PATH_1   -> if you keep a .session file on disk
# - SESSION_FILE_B64_1    -> useful for cloud platforms and long sessions
#
# Start with slot 1 only. Add slot 2-5 later if you need more assistants.
# ============================================================

# Recommended option:
SESSION_STRING_1=

# Alternative option:
SESSION_FILE_PATH_1=

# Alternative option for cloud hosting:
SESSION_FILE_B64_1=

# Optional extra assistants:
SESSION_STRING_2=
SESSION_FILE_PATH_2=
SESSION_FILE_B64_2=

SESSION_STRING_3=
SESSION_FILE_PATH_3=
SESSION_FILE_B64_3=

SESSION_STRING_4=
SESSION_FILE_PATH_4=
SESSION_FILE_B64_4=

SESSION_STRING_5=
SESSION_FILE_PATH_5=
SESSION_FILE_B64_5=


# ============================================================
# 5) REQUIRED EXTERNAL MUSIC SERVER
# This bot does NOT bundle a track server anymore.
# You must point it at your own external server.
#
# Minimum setup:
# - Fill MUSIC_MICROSERVICE_URL with one working base URL
#
# Expected endpoints on that server:
# - /search
# - /resolve
# - /health
# ============================================================
MUSIC_MICROSERVICE_URL=https://your-music-server.example.com
MUSIC_PROVIDER_PRIORITY=youtube,soundcloud,apple_music


# ============================================================
# 6) BASIC BOT BEHAVIOR
# Safe defaults for most users.
# ============================================================
MAX_QUEUE_SIZE=100
DEFAULT_VOLUME=100
COMMAND_COOLDOWN=3
AUTO_START_VC=true
AUTO_START_VC_TITLE=Music Bot Live
VC_PLAY_TIMEOUT=20
ASSISTANT_MAX_ACTIVE_CHATS=0


# ============================================================
# 7) AUDIO SETTINGS
# AUDIO_QUALITY can be: standard, high, premium, lossless
# If you are unsure, keep "high".
# ============================================================
AUDIO_QUALITY=high
AUDIO_BITRATE=192
AUDIO_LOUDNORM=true


# ============================================================
# 8) SEARCH / SOURCE POLICY
# Leave these as-is unless you know why you want different behavior.
# ============================================================
LEGAL_SOURCES_FIRST=true
PRIORITIZE_EXTRACTORS=true
PARALLEL_SEARCH=true


# ============================================================
# 9) NOW PLAYING / QUEUE UX
# Optional quality-of-life settings.
# ============================================================
NP_AUTOCLEAN_DELAY=30
SEARCH_MSG_AUTOCLEAN=8
NP_UPDATE_INTERVAL=3
ENABLE_PREVIOUS_TRACK=true
ENABLE_VC_DEBUG=true
ENABLE_QUEUE_EXPORT=true
ENABLE_AUTO_RETRY_USERBOT_AUTH=true


# ============================================================
# 10) SIMPLE STORAGE DEFAULTS
# These work well for local use, a small VPS, or first deployment.
# If you do nothing else, the bot can use SQLite paths below.
# ============================================================
SQLITE_CACHE_PATH=./data/cache.db
SQLITE_DB_PATH=./data/database.db


# ============================================================
# 11) OPTIONAL REDIS CACHE
# Use this if you want faster shared cache behavior.
# Leave empty to stay on SQLite cache.
# ============================================================
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=


# ============================================================
# 12) OPTIONAL UPSTASH REDIS
# Good for cloud setups where you do not want to run your own Redis.
# Fill this OR the REDIS_HOST block above, not both unless intentional.
# ============================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ============================================================
# 13) OPTIONAL HOSTED DATABASES
# Pick what fits your deployment. You do not need all of them.
#
# Recommended approach:
# - start with SQLite only
# - add one hosted database later if your deployment needs it
# ============================================================

# Legacy / existing deployments only.
# The current primary database path is Neon -> Supabase -> SQLite fallback.
# Leave this empty unless you have older tooling around this variable.
MONGO_URI=

# Supabase option:
SUPABASE_URL=
SUPABASE_KEY=

# Neon Postgres option:
NEON_DATABASE_URL=


# ============================================================
# 14) OPTIONAL TELEGRAM / ACCESS SETTINGS
# ============================================================
BOUND_GROUP_ID=
LOG_GROUP_ID=
BOT_USERNAME=
BOT_USERNAME_ALT=
ADMIN_PASSWORD=


# ============================================================
# 15) OPTIONAL WEBHOOK MODE
# Leave empty if you are using normal polling.
# Fill these only when your hosting setup is using webhooks.
# ============================================================
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=


# ============================================================
# 16) OPTIONAL METRICS
# Useful for hosted environments and monitoring dashboards.
# ============================================================
METRICS_HTTP_ENABLED=false
METRICS_HTTP_TOKEN=
METRICS_PROMETHEUS_ENABLED=false


# ============================================================
# 17) OPTIONAL MINI APP SETTINGS
# Only needed if you are also using the Telegram mini app flow.
# ============================================================
MINI_APP_WEB_URL=
MINI_APP_ALLOWED_ORIGINS=
MINI_APP_ALLOW_CREDENTIALS=false
MINI_APP_INITDATA_MAX_AGE_SECONDS=3600
MINI_APP_RATE_LIMIT_PER_MINUTE=180
MINI_APP_STREAM_PROXY_TIMEOUT_SECONDS=20
MINI_APP_STREAM_PROXY_SECRET=
MINI_APP_LOBBY_STATE_TTL_SECONDS=300
MINI_APP_SESSION_TTL_SECONDS=604800


# ============================================================
# 18) OPTIONAL EXTRA TOKENS
# ============================================================
GENIUS_TOKEN=


# ============================================================
# 19) PLATFORM NOTES
# Most users should not set these manually unless the host needs them.
# ============================================================
PORT=


# ============================================================
# 20) EXAMPLE MINIMUM CONFIG
# This is what a true minimum setup conceptually looks like:
#
# TELEGRAM_ENABLED=true
# API_ID=12345678
# API_HASH=0123456789abcdef0123456789abcdef
# BOT_TOKEN=1234567890:AAExampleBotTokenReplaceMe
# OWNER_ID=123456789
# SESSION_STRING_1=your_assistant_session_here
# MUSIC_MICROSERVICE_URL=https://your-music-server.example.com
# ============================================================


# ============================================================
# 21) BEFORE YOU START THE BOT
# Checklist:
# - API_ID and API_HASH are real values from my.telegram.org
# - BOT_TOKEN is real and copied from BotFather
# - OWNER_ID is your numeric Telegram user ID
# - one assistant auth method is filled for slot 1
# - MUSIC_MICROSERVICE_URL points to a live server
# - endpoint paths /search, /resolve, /health are available on that server
# - volumes or persistent storage are configured if you care about local data
# ============================================================
