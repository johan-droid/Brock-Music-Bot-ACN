# Brook Music Bot - minimal env template (Heroku-friendly)
# Only expose external credentials/endpoints here.

# Telegram app credentials (https://my.telegram.org)
TELEGRAM_ENABLED=true
API_ID=12345678
API_HASH=0123456789abcdef0123456789abcdef

# Bot token from @BotFather
BOT_TOKEN=1234567890:AAExampleBotTokenReplaceMe

# Owner Telegram user ID
OWNER_ID=123456789

# Assistant auth: fill ONE option for slot 1
SESSION_STRING_1=
SESSION_FILE_PATH_1=
SESSION_FILE_B64_1=

# External music service (required)
MUSIC_MICROSERVICE_URL=https://your-music-server.example.com

# Optional external services only
GENIUS_TOKEN=
NEON_DATABASE_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
