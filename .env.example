# Toggle Telegram mode (set FALSE to run without Telegram client auth)
TELEGRAM_ENABLED=true

# Telegram API credentials (get from https://my.telegram.org)
# Required only when TELEGRAM_ENABLED=true
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here
BOT_ID=your_bot_id_here
BOT_USERNAME=your_bot_username_here
BOT_USERNAME_ALT=your_previous_or_fallback_bot_username_here

# Optional group binder: when set, only this group/chat ID may use the bot
BOUND_GROUP_ID=

# Owner's Telegram user ID
OWNER_ID=your_user_id_here

# Userbot auth (choose one per assistant index)
# Preferred for production:
SESSION_STRING_1=your_session_string_1_here
# Optional fallback for container environments:
# SESSION_FILE_B64_1=your_base64_encoded_session_file_here
# SESSION_FILE_PATH_1=/app/sessions/userbot_1.session

# Optional additional assistants
SESSION_FILE_B64_2=
SESSION_FILE_B64_3=
SESSION_FILE_B64_4=
SESSION_FILE_B64_5=
SESSION_FILE_PATH_2=
SESSION_FILE_PATH_3=
SESSION_FILE_PATH_4=
SESSION_FILE_PATH_5=
SESSION_STRING_2=
SESSION_STRING_3=
SESSION_STRING_4=
SESSION_STRING_5=

# ============================================
# DATABASE OPTIONS (Choose ONE)
# Priority: Neon > Supabase > MongoDB > SQLite
# ============================================

# Option 1: Neon Database (Recommended - Serverless Postgres)
# Get free database at https://neon.tech
# NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Option 2: Supabase (alternative)
# SUPABASE_URL=https://xyzcompany.supabase.co
# SUPABASE_KEY=service_role_key_here

# Option 3: MongoDB (legacy support)
# Get free MongoDB Atlas at https://www.mongodb.com/atlas
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/musicbot

# Option 4: SQLite (Zero-cost, no external service needed)
# Leave all above empty to use SQLite automatically
NEON_DATABASE_URL=
SUPABASE_URL=
SUPABASE_KEY=
MONGO_URI=

# SQLite storage path (used when MongoDB is not configured)
SQLITE_DB_PATH=./data/bot.db

# ============================================
# CACHE OPTIONS (Choose ONE)
# ============================================

# Option 1: Redis (Better performance, requires Redis server)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Option 2: SQLite Cache (Zero-cost, no external service needed)
# Leave REDIS_HOST empty to use SQLite cache automatically
REDIS_HOST=
SQLITE_CACHE_PATH=./data/cache.db

# ============================================
# OPTIONAL FEATURES
# ============================================

# Genius API (optional - for lyrics)
GENIUS_TOKEN=

# Log group/channel ID (optional)
LOG_GROUP_ID=

# Bot settings
MAX_QUEUE_SIZE=100
DEFAULT_VOLUME=100
COMMAND_COOLDOWN=3

# ============================================
# VK + Deezer (optional provider backend)
# ============================================
# To enable VK/Deezer search and resolution, set the provider endpoints
# or tokens below. If you run a self-hosted VK/Deezer resolver, set
# `VK_API_BASE_URL` to its URL and `VK_API_TOKEN` if it requires auth.
# For Deezer, provide one or more tokens separated by commas in `DEEZER_TOKENS`.

VK_API_BASE_URL=
VK_API_TOKEN=
VK_SEARCH_PATH=/search
VK_RESOLVE_PATH=/resolve
VK_TOKEN_HEADER=Authorization

DEEZER_API_BASE_URL=https://api.deezer.com
DEEZER_TOKENS=
DEEZER_RESOLVE_URL=

# ============================================
# TELEGRAM MINI APP (Soul King)
# ============================================
# Frontend URL configured in BotFather menu button / web app button.
MINI_APP_WEB_URL=
# Comma-separated origins allowed by mini app backend CORS.
# Example: https://soul-king-mini.pages.dev,https://web.telegram.org
MINI_APP_ALLOWED_ORIGINS=
MINI_APP_ALLOW_CREDENTIALS=false
# Reject stale Telegram initData payloads older than this many seconds.
MINI_APP_INITDATA_MAX_AGE_SECONDS=3600
# Per-IP request limit for mini app backend.
MINI_APP_RATE_LIMIT_PER_MINUTE=180
# Proxy timeout when fetching upstream audio segments.
MINI_APP_STREAM_PROXY_TIMEOUT_SECONDS=20
# If empty, BOT_TOKEN is used as the stream proxy signing secret.
MINI_APP_STREAM_PROXY_SECRET=
# Lobby snapshot TTL in cache (seconds).
MINI_APP_LOBBY_STATE_TTL_SECONDS=300
# Session cache TTL in seconds (7 days).
MINI_APP_SESSION_TTL_SECONDS=604800


# ============================================
# ZERO-COST DEPLOYMENT NOTES
# ============================================
# 
# For completely free deployment with no external services:
# 1. Leave MONGO_URI empty to use SQLite database
# 2. Leave REDIS_HOST empty to use SQLite cache
# 3. Deploy to Railway, Render, Fly.io, or Oracle Cloud Free Tier
# 4. See DEPLOYMENT.md for detailed instructions
#
# Required minimum:
# - API_ID, API_HASH (from my.telegram.org)
# - BOT_TOKEN (from @BotFather)
# - SESSION_FILE_B64_1 (recommended, generated by generate_session.py)
#   or SESSION_FILE_PATH_1 / SESSION_STRING_1
# - OWNER_ID (your Telegram user ID)
