# ============================================
# CACHE OPTIONS (Choose ONE)
# ============================================

# Option 1: Redis (Better performance, requires Redis server)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Option 2: Upstash Redis (Serverless/Zero-cost)
UPSTASH_REDIS_REST_URL="https://feasible-grouper-88535.upstash.io"
UPSTASH_REDIS_REST_TOKEN="gQAAAAAAAVnXAAIncDEwNTFlNGQyMzcxYjI0YWI0OTdmNmZmOGU5NGYyZGU5OHAxODg1MzU"

# Option 3: SQLite Cache (Zero-cost, no external service needed)
# Leave REDIS_HOST and UPSTASH_REDIS_REST_URL empty to use SQLite cache automatically
REDIS_HOST=

# ============================================
# OPTIONAL FEATURES
# ============================================

# Genius API (optional - for lyrics)
GENIUS_TOKEN=

# Log group/channel ID (optional)
LOG_GROUP_ID=

# Bot settings
MAX_QUEUE_SIZE=100
DEFAULT_VOLUME=100
COMMAND_COOLDOWN=3

# Now Playing card auto-clean (seconds)
NP_AUTOCLEAN_DELAY=30
SEARCH_MSG_AUTOCLEAN=8
NP_UPDATE_INTERVAL=15

# yt-dlp concurrency & caching
YTDL_CONCURRENT_LIMIT=3
YTDL_CACHE_TTL=19800

# Audio quality
AUDIO_QUALITY=high
AUDIO_BITRATE=192
AUDIO_LOUDNORM=true

# ============================================
# ZERO-COST DEPLOYMENT NOTES
# ============================================
# 
# For completely free deployment with no external services:
# 1. Leave MONGO_URI empty to use SQLite database
# 2. Leave REDIS_HOST empty to use SQLite cache
# 3. Deploy to Railway, Render, Fly.io, or Oracle Cloud Free Tier
# 4. See DEPLOYMENT.md for detailed instructions
#
# Required minimum:
# - API_ID, API_HASH (from my.telegram.org)
# - BOT_TOKEN (from @BotFather)
# - SESSION_STRING_1 (generate with Pyrogram)
# - OWNER_ID (your Telegram user ID)
#
# Optional: lightweight HTTP metrics endpoint (adds JSON + Prometheus routes)
# When enabled, JSON metrics are available at `/metrics` and a Prometheus
# text exporter is available at `/metrics/prometheus` when enabled.
METRICS_HTTP_ENABLED=false
# Protect the HTTP metrics endpoint by setting a strong token here. Token can
# be passed as `Authorization: Bearer <token>` or `?token=<token>`.
METRICS_HTTP_TOKEN=
METRICS_PROMETHEUS_ENABLED=false

# --------------------------------------------
# VK + Deezer provider (optional)
# If you use a hosted VK/Deezer resolver, set the base URL and token here.
# For Deezer, provide comma-separated tokens in `DEEZER_TOKENS`.
# --------------------------------------------
VK_API_BASE_URL=https://resumedia-dad08deb221d.herokuapp.com
VK_API_TOKEN=
VK_SEARCH_PATH=/search
VK_RESOLVE_PATH=/resolve
VK_TOKEN_HEADER=Authorization

DEEZER_API_BASE_URL=https://api.deezer.com
DEEZER_TOKENS=
DEEZER_RESOLVE_URL=

# Remote music microservice (used by MusicBackend). Set to your deployed music
# microservice (Render, Fly, etc.). Example: https://brok-music-bot-microservice.onrender.com
MUSIC_MICROSERVICE_URL=https://brok-music-bot-microservice.onrender.com

# yt-dlp tuning
YTDL_CONCURRENT_LIMIT=3
YTDL_CACHE_TTL=19800
SESSION_FILE_B64_
